---
// src/pages/blog/[slug].astro
import Base from "../../layouts/Base.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

interface Props { post: CollectionEntry<"blog">; }
const { post } = Astro.props;
const { Content } = await post.render();

// Olvasási idő számítás (ha nincs frontmatterben)
const readingTime = post.data.readingTime
  ?? Math.ceil(post.body.split(/\s+/).length / 200);
---

<Base
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
  type="article"
  pubDate={post.data.pubDate}
  tags={post.data.tags}
>
  <article class="max-w-3xl mx-auto px-6 py-20">

    <!-- Breadcrumb -->
    <nav class="text-sm font-mono text-muted mb-8">
      <a href="/" class="hover:text-accent">Főoldal</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-accent">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-ink dark:text-paper">{post.data.title}</span>
    </nav>

    <!-- Meta -->
    <div class="mb-8">
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.tags.map(tag => (
          <a
            href={`/blog?tag=${tag}`}
            class="text-xs font-mono text-accent hover:underline"
          >
            {tag}
          </a>
        ))}
      </div>
      <h1 class="font-display text-4xl sm:text-5xl leading-tight mb-4">
        {post.data.title}
      </h1>
      <p class="text-lg text-muted mb-6">{post.data.description}</p>
      <div class="flex flex-wrap items-center gap-4 text-sm font-mono text-muted/60 pb-6 border-b border-ink/10 dark:border-paper/10">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("hu-HU", {
            year: "numeric", month: "long", day: "numeric"
          })}
        </time>
        <span>{readingTime} perces olvasás</span>
        {post.data.aiGenerated && (
          <span class="border border-muted/30 px-2 py-0.5 rounded-sm text-xs">
            AI-asszisztált · {post.data.aiModel}
          </span>
        )}
        {post.data.updatedDate && (
          <span>
            Frissítve: {post.data.updatedDate.toLocaleDateString("hu-HU")}
          </span>
        )}
      </div>
    </div>

    <!-- Hero image -->
    {post.data.heroImage && (
      <img
        src={post.data.heroImage}
        alt={post.data.title}
        class="w-full aspect-[16/9] object-cover rounded-sm mb-10"
      />
    )}

    <!-- Content -->
    <div class="prose prose-lg dark:prose-invert max-w-none
                prose-headings:font-display prose-headings:font-normal
                prose-a:text-accent prose-a:no-underline hover:prose-a:underline
                prose-code:font-mono prose-code:text-sm
                prose-pre:bg-ink dark:prose-pre:bg-paper/5
                prose-img:rounded-sm">
      <Content />
    </div>

    <!-- Nav: előző / következő (TODO: getStaticPaths-ból) -->
    <div class="mt-16 pt-8 border-t border-ink/10 dark:border-paper/10">
      <a href="/blog" class="text-sm font-mono text-muted hover:text-accent transition-colors">
        ← Vissza a blogra
      </a>
    </div>

  </article>
</Base>
