---
// src/layouts/Base.astro
// Alap layout: SEO meta, JSON-LD, Google Fonts, dark mode toggle

export interface Props {
  title:       string;
  description: string;
  image?:      string;
  type?:       "website" | "article";
  pubDate?:    Date;
  tags?:       string[];
}

const {
  title,
  description,
  image = "/og-default.png",
  type  = "website",
  pubDate,
  tags  = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage      = new URL(image, Astro.site);
const siteName     = "Your Name – Dev";

// JSON-LD schema
const schema = type === "article"
  ? {
      "@context": "https://schema.org",
      "@type":    "BlogPosting",
      headline:   title,
      description,
      image:      ogImage.toString(),
      datePublished: pubDate?.toISOString(),
      author: { "@type": "Person", name: "Your Name" },
    }
  : {
      "@context": "https://schema.org",
      "@type":    "WebSite",
      name:       siteName,
      url:        Astro.site?.toString(),
    };
---

<!DOCTYPE html>
<html lang="hu" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO -->
  <title>{title} | {siteName}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}

  <!-- OG / Social -->
  <meta property="og:type"        content={type} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:site_name"   content={siteName} />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"      content={ogImage} />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Fonts (Google Fonts – preconnect + display=swap) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,400;9..40,500&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Dark mode: inline script, flicker-mentes -->
  <script is:inline>
    (function () {
      const stored = localStorage.getItem("theme");
      const pref   = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (stored === "dark" || (!stored && pref)) {
        document.documentElement.classList.add("dark");
      }
    })();
  </script>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body class="bg-paper dark:bg-ink text-ink dark:text-paper font-body antialiased">

  <!-- Skip link (a11y) -->
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-accent text-white px-3 py-1 rounded">
    Ugrás a tartalomhoz
  </a>

  <!-- Nav -->
  <header class="sticky top-0 z-50 border-b border-ink/10 dark:border-paper/10 bg-paper/90 dark:bg-ink/90 backdrop-blur-sm">
    <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-display text-xl font-normal tracking-tight hover:text-accent transition-colors">
        YN<span class="text-accent">.</span>
      </a>
      <div class="flex items-center gap-6 text-sm font-body">
        <a href="/blog"    class="hover:text-accent transition-colors">Blog</a>
        <a href="/projektek" class="hover:text-accent transition-colors">Projektek</a>
        <a href="/rolam"   class="hover:text-accent transition-colors">Rólam</a>
        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          aria-label="Téma váltás"
          class="w-8 h-8 flex items-center justify-center rounded-full border border-ink/20 dark:border-paper/20 hover:border-accent transition-colors"
        >
          <span class="dark:hidden">☾</span>
          <span class="hidden dark:inline">☀︎</span>
        </button>
      </div>
    </nav>
  </header>

  <main id="main">
    <slot />
  </main>

  <footer class="border-t border-ink/10 dark:border-paper/10 mt-24">
    <div class="max-w-5xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted">
      <p>© {new Date().getFullYear()} Your Name. Minden jog fenntartva.</p>
      <div class="flex gap-6">
        <a href="https://github.com/yourhandle" class="hover:text-accent transition-colors" target="_blank" rel="noopener">GitHub</a>
        <a href="https://linkedin.com/in/yourhandle" class="hover:text-accent transition-colors" target="_blank" rel="noopener">LinkedIn</a>
        <a href="/rss.xml" class="hover:text-accent transition-colors">RSS</a>
      </div>
    </div>
  </footer>

  <!-- Dark mode JS -->
  <script>
    document.getElementById("theme-toggle")?.addEventListener("click", () => {
      const html = document.documentElement;
      html.classList.toggle("dark");
      localStorage.setItem("theme", html.classList.contains("dark") ? "dark" : "light");
    });
  </script>

</body>
</html>
